    "Descriptions": [
        {
            "CategoryName": "Welcome",
            "Descriptions": [
                {
                    "DescriptionText": "Welcome to KRONJON-Hashima-PvE. This server is built around survival, exploration, vehicles, and the Hashima map."
                },
                {
                    "DescriptionText": "Use the book for server information, rules, party tools, territory tools, and useful links."
                },
                {
                    "DescriptionText": "Join Discord for announcements, support, server feedback, and the latest information about events or configuration changes."
                },
                {
                    "DescriptionText": "Note this is not a heavily moderate server, but ask in the discord if you have questions or problems and we'll try and help!"
                }
            ]
        },
        {
            "CategoryName": "Gameplay Notes",
            "Descriptions": [
                {
                    "DescriptionText": "Roaming AI patrols are active. Some bots may look like players, so stay alert when moving through the map."
                },
                {
                    "DescriptionText": "Check the Discord link on the server info page when you need help or want to report a problem."
                }
            ]
        },
        {
            "CategoryName": "Airborne AI",
            "Descriptions": [
                {
                    "DescriptionText": "Every few hours, a hostile aircraft may fly over the island. If it spots you, it can drop several hostile AI nearby who will hunt you."
                },
                {
                    "DescriptionText": "Reinforcements flares for the flare gun call in a friendly aircraft. When fired, it will drop a few friendly bots near your location."
                },
                {
                    "DescriptionText": "Each party member can approach one friendly bot and press F to recruit them. Recruited bots will follow you and fight alongside you."
                },
                {
                    "DescriptionText": "Call reinforcements from wide, flat ground when possible. If they drop into water, they may not be able to get out, and they can sometimes die if they hit trees while landing."
                }
            ]
        }
    ],
