            "CategoryName": "General",
            "Rules": [
                {
                    "RuleParagraph": "1.1.",
                    "RuleText": "Keep chat and voice comms respectful. Harassment, hate speech, and toxic behavior are not welcome here."
                },
                {
                    "RuleParagraph": "1.2.",
                    "RuleText": "Do not use cheats, exploits, duping methods, or external tools that create an unfair advantage."
                },
                {
                    "RuleParagraph": "1.3.",
                    "RuleText": "Roaming AI patrols can look like players. Identify targets carefully and expect hostile contact away from towns."
                },
                {
                    "RuleParagraph": "1.4.",
                    "RuleText": "Use Discord for questions, bug reports, event info, and server announcements."
                },
                {
                    "RuleParagraph": "1.5.",
                    "RuleText": "Admins may remove players or items when needed to protect server stability and fair play."
                }
            ]
        }
    ],
